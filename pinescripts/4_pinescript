//@version=5
strategy("4", overlay=true, process_orders_on_close=true)

startTime = timestamp(2010, 1, 19, 0, 0)

red = close < open
upclose = close > close[1]

var int count = 0

if red
    count += 1
else
    count := 0

entry = (count == 3) and (strategy.position_size == 0) and (time >= startTime)
exit = (strategy.position_size > 0) and upclose

if entry
    strategy.entry("BUY", strategy.long)

if exit
    strategy.close("BUY")